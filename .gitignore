# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
build/
dist/

# Virtual environments
.venv/
venv/
env/
ENV/

# Environment variables
.env

# Editor / OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# Project data
data/raw/*
data/processed/*
reports/*
!data/raw/.gitkeep
!data/processed/.gitkeep
!reports/.gitkeep

# DuckDB is tracked so Railway/CI can serve it without re-ingesting
# Re-run `ingest` locally then commit db/valorant.duckdb to update
db/*
!db/.gitkeep
!db/*.duckdb

# Notes are tracked for deployment persistence
data/notes/
