HENRIK_API_KEY=
VALORANT_REGION=ap
VALORANT_NAME=
VALORANT_TAG=
MATCH_SIZE=10

# Premier team identification (preferred way to fetch official league matches).
# Use your Premier team's display name and 3-character tag, NOT your personal Riot ID.
PREMIER_TEAM_NAME=
PREMIER_TEAM_TAG=

# Optional: override / pin the analyzed roster.
# Comma-separated Riot IDs (Name#Tag) or raw PUUIDs.
# If left empty, the team's official members from the Premier API are used.
PREMIER_ROSTER=
ROSTER_MIN_PRESENT=4

# --- Deployment ---
# Vercel frontend origin(s) to allow in CORS (comma-separated).
# Set this on Railway to your Vercel deployment URL.
# Example: CORS_ORIGINS=https://your-app.vercel.app
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

